# База данных PostgreSQL (обязательно)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Пароль администратора сайта (для входа в /admin)
ADMIN_PASSWORD=смените_этот_пароль

# Секрет для сессий (любая длинная случайная строка, минимум 32 символа)
SESSION_SECRET=смените_на_случайную_строку_минимум_32_символа

# Порт API-сервера
PORT=8080

# URL фронтенда (для CORS, опционально)
FRONTEND_URL=https://your-frontend-domain.com

# Telegram бот (настраивается в панели администратора /admin)
# TELEGRAM_BOT_TOKEN=123456789:AAF...
# TELEGRAM_ADMIN_CHAT_ID=123456789
